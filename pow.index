<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Portfolio of Burhan Ahmad - Web3 Community Manager and DeFi Enthusiast.">
  <title>BurhanAhmad.Web3 | Community & DeFi Professional</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class', 
      theme: {
        extend: {
          fontFamily: { sans: ['Space Grotesk', 'sans-serif'] },
          colors: {
            'primary-web3': '#2563eb',
            'secondary-web3': '#10b981',
            'dark-background': '#111827',
            'dark-card': '#1f2937',
          },
          keyframes: {
            'subtle-glow': {
              '0%, 100%': { 'box-shadow': '0 0 10px rgba(16, 185, 129, 0.5)' },
              '50%': { 'box-shadow': '0 0 20px rgba(16, 185, 129, 0.8)' },
            }
          },
          animation: { 'subtle-glow': 'subtle-glow 3s ease-in-out infinite alternate' }
        },
      },
    };
  </script>
  <style>
    body { scroll-behavior: smooth; }
    
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    .card-hover-3d { transition: all 0.4s ease; }
    .card-hover-3d:hover {
        transform: translateY(-10px) rotateX(2deg);
        box-shadow: 0 20px 40px rgba(16, 185, 129, 0.15);
    }

    .x-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }
    .x-btn:hover {
        background: #000;
        border-color: #1d9bf0;
        color: #1d9bf0;
        transform: scale(1.1);
    }

    /* Updated Timeline Line: Starts from first dot, ends at last */
    .timeline-line {
        position: absolute; left: 50%; top: 50px; bottom: 100px;
        width: 4px; background: linear-gradient(to bottom, #10b981, #374151);
        transform: translateX(-50%); z-index: 1;
    }
    .timeline-dot {
        position: absolute; width: 1.5rem; height: 1.5rem;
        border-radius: 50%; background: #10b981;
        left: 50%; transform: translate(-50%, -50%);
        border: 4px solid #111827; z-index: 10;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.5);
    }

    @media (max-width: 768px) {
        .timeline-line, .timeline-dot { display: none; }
        .reveal { opacity: 1; transform: none; }
    }
  </style>
</head>
<body class="bg-dark-background text-gray-100 font-sans overflow-x-hidden">

<nav id="nav" class="fixed top-0 w-full bg-dark-background/90 backdrop-blur-md border-b border-gray-800 z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
    <div class="font-bold text-2xl tracking-tighter text-secondary-web3">BurhanAhmad.<span class="text-gray-200">Web3</span></div> 
    <div class="flex gap-8">
      <a href="#about" class="hover:text-secondary-web3 transition-colors font-medium">About</a>
      <a href="#experience" class="hover:text-secondary-web3 transition-colors font-medium">Experience</a>
    </div>
  </div>
</nav>

<section class="min-h-screen flex flex-col items-center justify-center text-center px-4 pt-20">
    <div class="reveal">
        <h1 class="text-6xl md:text-8xl font-bold mb-6 tracking-tight">
          Hi, I'm <span class="text-secondary-web3">Burhan Ahmad</span>
        </h1>
        <p class="text-xl md:text-3xl text-gray-400 mb-10 font-light">Web3 Community Builder & DeFi Enthusiast</p>
        <a href="#experience" class="inline-block bg-primary-web3 hover:bg-blue-600 text-white px-10 py-4 rounded-full text-lg font-bold transition-all transform hover:scale-105 shadow-lg shadow-primary-web3/20">
          Explore My Journey ↓
        </a>
    </div>
</section>

<section id="about" class="py-32 px-6 bg-dark-card/30">
  <div class="max-w-6xl mx-auto reveal">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
            <img src="https://pbs.twimg.com/profile_images/1968019258668978177/t-TuTM4R_400x400.jpg" alt="Burhan Ahmad" class="w-64 h-64 md:w-80 md:h-80 rounded-3xl mx-auto object-cover border-2 border-secondary-web3 animate-subtle-glow relative z-10">
            <div class="absolute inset-0 bg-secondary-web3/20 blur-[80px] rounded-full"></div>
        </div>
        <div class="space-y-6">
            <h2 class="text-4xl md:text-5xl font-bold text-secondary-web3">About Me</h2>
            <p class="text-xl leading-relaxed text-gray-300">
                I'm a Mod jobs lover with 4+ years of experience in moderation. I turn communities into assets, not just chat rooms. I bridge the gap between complex DeFi protocols and thriving user communities.
            </p>
            <div class="flex flex-wrap gap-3">
                <span class="px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-secondary-web3 text-sm">DeFi & NFT</span>
                <span class="px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-secondary-web3 text-sm">Alpha Hunting</span>
                <span class="px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-secondary-web3 text-sm">Communication</span>
                <span class="px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-secondary-web3 text-sm">Community Growth</span>
                <span class="px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-secondary-web3 text-sm">Game Nights Hoster</span>
                <span class="px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-secondary-web3 text-sm">Collab Manager</span>
                <span class="px-4 py-2 bg-dark-card border border-gray-700 rounded-lg text-secondary-web3 text-sm">Discord Setup</span>
            </div>
        </div>
    </div>
  </div>
</section>

